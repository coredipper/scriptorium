{
  "name": "scriptorium-obsidian-plugin",
  "version": "0.1.0",
  "description": "In-app health (scrip status/verify) and relationship navigation (facts/graph.ndjson) for a scriptorium vault.",
  "main": "main.js",
  "type": "module",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "tsc --noEmit --skipLibCheck && node esbuild.config.mjs production",
    "typecheck": "tsc --noEmit --skipLibCheck",
    "test": "node --test \"src/*.test.ts\""
  },
  "keywords": ["obsidian", "scriptorium", "knowledge-base"],
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^22.5.0",
    "builtin-modules": "^4.0.0",
    "esbuild": "^0.23.0",
    "obsidian": "^1.7.2",
    "tslib": "^2.6.0",
    "typescript": "^5.5.0"
  }
}
