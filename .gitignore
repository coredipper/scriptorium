# Python / uv
.venv/
**/.venv/
__pycache__/
*.pyc
*.egg-info/
dist/
build/

# DuckDB scratch / temp writes
*.duckdb
*.duckdb.wal
*.tmp

# OS
.DS_Store

# Secrets: harness wiki-publish credentials (gh_username/password/wikirepo).
# Never commit. The real file lives with the private KB, not in this repo.
.env

# Embeddings index: a large, regenerable binary cache (rebuild with `scrip index`)
/.kb/embeddings/

# Advisory write lock: ephemeral runtime state, never committed (see SPEC §11)
/.kb/lock

# Manifest: a regenerable speed cache. SPEC §8 says it *may* be committed; we
# choose not to — it stores (mtime, size) that are wrong on every fresh clone
# anyway, and its hashes/timestamps churn diffs. Rebuild any time with
# `scrip status --rebuild-manifest`.
/.kb/manifest.json

# roborev snapshots
/.roborev/

# Obsidian local state: created when you open vault/ in Obsidian (UI config,
# sideloaded plugin copies). Local-only; the vault is valid without it.
vault/.obsidian/
